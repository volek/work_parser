# =============================================================================
# Docker Ignore - исключения при сборке образа
# =============================================================================

# Gradle build artifacts
build/
.gradle/
out/

# IDE files
.idea/
*.iml
*.ipr
*.iws
.vscode/
*.swp
*.swo

# Git
.git/
.gitignore
.gitattributes

# Docker files (не нужны внутри контейнера)
Dockerfile*
docker-compose*.yml
.dockerignore

# Documentation
*.md
!README.md
docs/

# Logs
logs/
*.log

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
*.bak
*~

# Test coverage
coverage/
.coverage

# Local configuration
config.local.yaml
*.local.*
.env
.env.local
.env.*.local

# Node modules (if any frontend)
node_modules/

# Python virtual environment (if any)
venv/
__pycache__/
*.pyc
