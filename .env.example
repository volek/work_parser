# =============================================================================
# BPM Message Parser - Linux host environment
# =============================================================================
# Запуск проекта поддерживается только на Linux host.
# Пример:
#   set -a && source .env && set +a
#   java -jar build/libs/bpm-druid-parser-1.0.0.jar help
# =============================================================================

# Druid endpoints (локальный или удаленный кластер)
DRUID_BROKER_URL=http://192.168.1.27:8082
DRUID_COORDINATOR_URL=http://192.168.1.27:8081
DRUID_OVERLORD_URL=http://192.168.1.27:8081
DRUID_ROUTER_URL=http://192.168.1.27:8888

# Optional auth
# DRUID_USERNAME=user
# DRUID_PASSWORD=secret

# Optional TLS
# DRUID_TRUST_STORE_PATH=/absolute/path/to/druid-truststore.p12
# DRUID_TRUST_STORE_PASSWORD=changeit
# DRUID_TRUST_STORE_TYPE=PKCS12
# DRUID_INSECURE_SKIP_TLS_VERIFY=false

# Connection settings
DRUID_CONNECT_TIMEOUT=30000
DRUID_READ_TIMEOUT=60000
DRUID_BATCH_SIZE=1000
DRUID_MAX_INLINE_BYTES=4000000
DRUID_AWAIT_INGESTION_TASKS=true
DRUID_INGESTION_TASK_TIMEOUT_MS=1800000
DRUID_INGESTION_TASK_POLL_INTERVAL_MS=2000

# Parser tuning
# PARSER_WARM_VARIABLES_LIMIT=110
