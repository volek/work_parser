# =============================================================================
# BPM Message Parser - Environment Configuration
# =============================================================================
# Скопируйте этот файл в .env и настройте под ваше окружение:
#   cp .env.example .env
#
# Варианты подключения к Druid:
#   1. Standalone Druid на хосте (порт 8888)
#   2. Druid в docker-compose.druid.yml (через сеть druid-network)
#   3. Удалённый Druid кластер
# =============================================================================

# -----------------------------------------------------------------------------
# Вариант 1: Standalone Druid на хосте (по умолчанию)
# -----------------------------------------------------------------------------
# Используется host.docker.internal для доступа к localhost хоста из контейнера
DRUID_BROKER_URL=http://192.168.1.27:8082
DRUID_COORDINATOR_URL=http://192.168.1.27:8081
DRUID_OVERLORD_URL=http://192.168.1.27:8090
DRUID_ROUTER_URL=http://192.168.1.27:8888

# -----------------------------------------------------------------------------
# Вариант 2: Druid в docker-compose.druid.yml
# -----------------------------------------------------------------------------
# Раскомментируйте, если Druid запущен через docker-compose.druid.yml
# и приложение подключено к сети druid-network
# DRUID_BROKER_URL=http://druid-broker:8082
# DRUID_COORDINATOR_URL=http://druid-coordinator:8081
# DRUID_OVERLORD_URL=http://druid-overlord:8090
# DRUID_ROUTER_URL=http://druid-router:8888

# -----------------------------------------------------------------------------
# Вариант 3: Удалённый Druid кластер
# -----------------------------------------------------------------------------
# DRUID_BROKER_URL=http://druid-prod.example.com:8082
# DRUID_COORDINATOR_URL=http://druid-prod.example.com:8081
# DRUID_OVERLORD_URL=http://druid-prod.example.com:8090
# DRUID_ROUTER_URL=http://druid-prod.example.com:8888

# -----------------------------------------------------------------------------
# Connection Settings
# -----------------------------------------------------------------------------
DRUID_CONNECT_TIMEOUT=30000
DRUID_READ_TIMEOUT=60000
DRUID_BATCH_SIZE=1000

# -----------------------------------------------------------------------------
# JVM Settings
# -----------------------------------------------------------------------------
JAVA_OPTS=-Xms256m -Xmx512m
