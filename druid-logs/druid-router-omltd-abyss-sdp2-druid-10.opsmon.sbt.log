2026-04-06T11:39:13,251 INFO [qtp1401633928-161] org.apache.druid.java.util.emitter.core.LoggingEmitter - {"feed":"metrics","metric":"query/time","service":"druid/router","success":"true","host":"omltd-abyss-sdp2-druid-10.opsmon.sbt:9088","id":"4993463d-d608-4e16-a8e6-ae2019f00421","version":"31.0.0","value":23,"remoteAddress":"10.21.12.135","timestamp":"2026-04-06T11:39:13.251Z"}
2026-04-06T11:39:13,252 INFO [qtp1401633928-161] org.apache.druid.java.util.emitter.core.LoggingEmitter - {"feed":"druid_requests","remoteAddr":"10.21.12.135","service":"druid/router","timestamp":"2026-04-06T11:39:13.252Z","sql":"SELECT \n    pe.state,\n    pv.var_path,\n    COUNT(*) as cnt\nFROM eav_process_events pe\nJOIN eav_process_variables pv ON pe.process_id = pv.process_id\nWHERE pe.state = 2\nGROUP BY pe.state, pv.var_path\nORDER BY cnt DESC\nLIMIT 50","queryStats":{"query/time":23,"success":true,"identity":"admin"},"sqlQueryContext":{"sqlQueryId":"4993463d-d608-4e16-a8e6-ae2019f00421","queryId":"4993463d-d608-4e16-a8e6-ae2019f00421"},"query":null,"host":"omltd-abyss-sdp2-druid-10.opsmon.sbt:9088"}
2026-04-06T11:39:14,977 INFO [qtp1401633928-181] org.apache.druid.java.util.emitter.core.LoggingEmitter - {"feed":"metrics","metric":"query/time","service":"druid/router","success":"true","host":"omltd-abyss-sdp2-druid-10.opsmon.sbt:9088","id":"7a950efb-9caf-4b36-b3d1-a1c4ea84b5a1","version":"31.0.0","value":63,"remoteAddress":"10.21.12.135","timestamp":"2026-04-06T11:39:14.977Z"}
2026-04-06T11:39:14,977 INFO [qtp1401633928-181] org.apache.druid.java.util.emitter.core.LoggingEmitter - {"feed":"druid_requests","remoteAddr":"10.21.12.135","service":"druid/router","timestamp":"2026-04-06T11:39:14.977Z","sql":"SELECT \n    pe.process_id,\n    COUNT(DISTINCT pv.var_path) as unique_paths\nFROM eav_process_events pe\nJOIN eav_process_variables pv ON pe.process_id = pv.process_id\nGROUP BY pe.process_id\nORDER BY unique_paths DESC","queryStats":{"query/time":63,"success":true,"identity":"admin"},"sqlQueryContext":{"sqlQueryId":"7a950efb-9caf-4b36-b3d1-a1c4ea84b5a1","queryId":"7a950efb-9caf-4b36-b3d1-a1c4ea84b5a1"},"query":null,"host":"omltd-abyss-sdp2-druid-10.opsmon.sbt:9088"}
