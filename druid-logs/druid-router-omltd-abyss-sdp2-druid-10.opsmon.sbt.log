2026-04-06T11:38:18,270 INFO [qtp1401633928-110] org.apache.druid.java.util.emitter.core.LoggingEmitter - {"feed":"druid_requests","remoteAddr":"10.21.12.135","service":"druid/router","timestamp":"2026-04-06T11:38:18.270Z","sql":"SELECT \n    pe.process_id,\n    pe.process_id as process_name,\n    SUM(CASE WHEN pv.var_path = 'epkId' THEN 1 ELSE 0 END) as epkId_cnt,\n    SUM(CASE WHEN pv.var_path = 'fio' THEN 1 ELSE 0 END) as fio_cnt,\n    SUM(CASE WHEN pv.var_path = 'caseId' THEN 1 ELSE 0 END) as caseId_cnt\nFROM eav_process_events pe\nJOIN eav_process_variables pv ON pe.process_id = pv.process_id\nWHERE pv.var_path IN ('epkId', 'fio', 'caseId')\nGROUP BY pe.process_id","queryStats":{"query/time":82,"success":true,"identity":"admin"},"sqlQueryContext":{"sqlQueryId":"12898962-7447-4558-bbde-f48060f2673a","queryId":"12898962-7447-4558-bbde-f48060f2673a"},"query":null,"host":"omltd-abyss-sdp2-druid-10.opsmon.sbt:9088"}
