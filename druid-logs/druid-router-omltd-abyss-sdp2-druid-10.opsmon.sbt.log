2026-04-06T11:38:14,876 INFO [qtp1401633928-130] org.apache.druid.java.util.emitter.core.LoggingEmitter - {"feed":"druid_requests","remoteAddr":"10.21.12.135","service":"druid/router","timestamp":"2026-04-06T11:38:14.876Z","sql":"SELECT \n    LENGTH(var_path) - LENGTH(REPLACE(var_path, '.', '')) + 1 as depth,\n    COUNT(*) as cnt_total\nFROM eav_process_variables\nGROUP BY 1\nORDER BY depth","queryStats":{"query/time":56,"success":true,"identity":"admin"},"sqlQueryContext":{"sqlQueryId":"f5a2e9f1-5563-4885-a96f-71339ecf52d9","queryId":"f5a2e9f1-5563-4885-a96f-71339ecf52d9"},"query":null,"host":"omltd-abyss-sdp2-druid-10.opsmon.sbt:9088"}
2026-04-06T11:38:16,599 INFO [qtp1401633928-139] org.apache.druid.java.util.emitter.core.LoggingEmitter - {"feed":"metrics","metric":"query/time","service":"druid/router","success":"true","host":"omltd-abyss-sdp2-druid-10.opsmon.sbt:9088","id":"3b7ae097-0487-4a88-af7e-a1172fadc22b","version":"31.0.0","value":72,"remoteAddress":"10.21.12.135","timestamp":"2026-04-06T11:38:16.599Z"}
2026-04-06T11:38:16,599 INFO [qtp1401633928-139] org.apache.druid.java.util.emitter.core.LoggingEmitter - {"feed":"druid_requests","remoteAddr":"10.21.12.135","service":"druid/router","timestamp":"2026-04-06T11:38:16.599Z","sql":"SELECT \n    pe.process_id,\n    pe.process_id,\n    epk.var_value as epkId,\n    cid.var_value as caseId\nFROM eav_process_events pe\nLEFT JOIN eav_process_variables epk \n    ON pe.process_id = epk.process_id AND epk.var_path = 'epkId'\nLEFT JOIN eav_process_variables cid \n    ON pe.process_id = cid.process_id AND cid.var_path = 'caseId'\nWHERE epk.var_value IS NOT NULL OR cid.var_value IS NOT NULL\nLIMIT 50","queryStats":{"query/time":72,"success":true,"identity":"admin"},"sqlQueryContext":{"sqlQueryId":"3b7ae097-0487-4a88-af7e-a1172fadc22b","queryId":"3b7ae097-0487-4a88-af7e-a1172fadc22b"},"query":null,"host":"omltd-abyss-sdp2-druid-10.opsmon.sbt:9088"}
